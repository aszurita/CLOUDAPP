APP_NAME=Enterprise CloudOps & DataOps Autopilot
ENVIRONMENT=local
API_PREFIX=/api
DATABASE_URL=sqlite:///./cloudapp.db
FRONTEND_ORIGINS=http://localhost:5173

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=chat-latest
OPENAI_MAX_OUTPUT_TOKENS=800
OPENAI_TEMPERATURE=0.2

DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_JOB_ID=
DATABRICKS_CATALOG=databricks_proyectobg
DATABRICKS_SCHEMA_BRONZE=tpcds_bronze
DATABRICKS_SCHEMA_SILVER=tpcds_silver
DATABRICKS_SCHEMA_GOLD=tpcds_gold
DATAOPS_PIPELINES_JSON=

CATALOG_PROVIDER=internal
DATAHUB_ENABLED=false
DATAHUB_SERVER=
DATAHUB_TOKEN=
PURVIEW_ENABLED=false
PURVIEW_ENDPOINT=
PURVIEW_ACCOUNT_NAME=
PURVIEW_TENANT_ID=
PURVIEW_CLIENT_ID=
PURVIEW_CLIENT_SECRET=

SENTINEL_MONITOR_DB_URL=
SENTINEL_MONITOR_DATABASE_NAME=core_banking_sim
SENTINEL_MODEL_PATH=./artifacts/incident_predictor.pkl
SENTINEL_RCA_MODEL_PATH=./artifacts/root_cause_model.pkl
SENTINEL_FEATURE_SCHEMA_PATH=./artifacts/feature_schema.json
SENTINEL_OPENAI_API_KEY=
SENTINEL_LLM_MODEL=gpt-4o-mini
SENTINEL_COLLECT_INTERVAL_SECONDS=60
SENTINEL_PREDICTION_HORIZON_MINUTES=10
SENTINEL_RISK_THRESHOLD=0.70
SENTINEL_ENABLE_AUTO_COLLECT=false
